# Copy this file to .env.local and fill in real values.
# .env.local is gitignored and never committed.
#
# NOTE: the public Firebase client config (apiKey, authDomain, etc.) is
# hardcoded directly in lib/firebase.ts — those values are safe to hardcode
# since they're already visible in the browser on any live Firebase web app.
# Only the genuinely secret Admin SDK credentials need to be set here.

FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
ADMIN_EMAIL=
